# ─────────────────────────────────────────────────────────────
# LifePilot environment configuration
# Copy this file to ".env" and fill in values as needed.
# The prototype runs FULLY with NO keys at all (offline mock LLM).
# Everything here is optional and free.
# ─────────────────────────────────────────────────────────────

# App
APP_NAME=LifePilot
ENVIRONMENT=development

# Database (SQLite by default = zero setup, single local file).
# To use PostgreSQL later, set e.g.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/lifepilot
DATABASE_URL=sqlite:///./lifepilot.db

# CORS (comma-separated). Frontend is served by the same server, so "*" is fine locally.
ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────────────────────
# LLM PROVIDER (all optional & free)
#   mock   -> deterministic, no downloads, works instantly (DEFAULT)
#   ollama -> local models via Ollama (https://ollama.com) 100% free/offline
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=mock

# Only used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
